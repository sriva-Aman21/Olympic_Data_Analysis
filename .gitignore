
---

# 📄 .gitignore

```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
venv/
env/
ENV/

# Streamlit
.streamlit/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Large datasets (optional if needed)
# Uncomment if your CSV is large
# *.csv

# Environment variables
.env
